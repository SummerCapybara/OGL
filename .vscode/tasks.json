{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build and Run Current File",
            "type": "shell",
            "command": "g++ -g ${file} include/glad/glad.c -Iinclude -lglfw -lGL -ldl -o ${fileDirname}/${fileBasenameNoExtension} && ${fileDirname}/${fileBasenameNoExtension} && rm ${fileDirname}/${fileBasenameNoExtension}",
            "windows": {
                "command": "powershell",
                "args": [
                    "/c",
                    "g++ -g \"${file}\" include/glad/glad.c -Iinclude -Llib -lglfw3 -lopengl32 -lgdi32 -o \"${fileDirname}\\${fileBasenameNoExtension}.exe\" ; & \"${fileDirname}\\${fileBasenameNoExtension}.exe\""
                ]
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "Compile and run the currently opened file with OpenGL"
        },
    ]
}